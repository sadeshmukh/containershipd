# Required
ADMIN_SECRET=change-me-to-a-long-random-string
JWT_SECRET=another-long-random-secret
ENCRYPTION_KEY=exactly-32-characters-long-here!

# Optional (shown with defaults)
LISTEN_ADDR=:8080
DATABASE_PATH=/var/lib/containershipd/containershipd.db
DATA_DIR=/var/lib/containershipd

# Set this to your public URL to enable GitHub auto-redeploy webhooks
# WEBHOOK_BASE_URL=https://myapp.example.com

# Set these to enable Traefik reverse proxy with automatic HTTPS (Let's Encrypt).
# Deployments can then be assigned a subdomain of BASE_DOMAIN.
# BASE_DOMAIN=app.example.com
# ACME_EMAIL=you@example.com

# Required when running containershipd inside Docker and DATA_DIR is bind-mounted
# under a different host path. Set to the host-side path that maps to DATA_DIR so
# that Docker can resolve nginx.conf bind mounts for deployment sidecars.
# Example: if your compose has "- ./data:/var/lib/containershipd", set:
#   DATA_DIR=/var/lib/containershipd
#   HOST_DATA_DIR=/absolute/path/to/your/data
# If running bare-metal, leave this unset (defaults to DATA_DIR).
# HOST_DATA_DIR=
